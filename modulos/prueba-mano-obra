<!DOCTYPE html>
<html lang="es">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Prueba Mano de Obra</title>
    <style>
        body { font-family: Arial; padding: 20px; }
        table { width: 100%; border-collapse: collapse; margin-top: 20px; }
        th, td { border: 1px solid #ddd; padding: 8px; text-align: left; }
        th { background: #003B68; color: white; }
        button { background: #27ae60; color: white; border: none; padding: 10px 20px; cursor: pointer; margin: 5px; border-radius: 5px; }
        .btn-danger { background: #e74c3c; }
        .modal { display: none; position: fixed; top: 0; left: 0; width: 100%; height: 100%; background: rgba(0,0,0,0.5); z-index: 1000; }
        .modal-content { background: white; margin: 100px auto; padding: 20px; width: 400px; border-radius: 10px; }
        input, select { width: 100%; padding: 8px; margin: 5px 0 15px 0; border: 1px solid #ddd; border-radius: 5px; }
        label { font-weight: bold; }
        .mensaje { padding: 10px; margin: 10px 0; border-radius: 5px; }
        .exito { background: #d4edda; color: #155724; }
        .error { background: #f8d7da; color: #721c24; }
    </style>
</head>
<body>
    <h2>👷 Prueba - Mano de Obra (FAENA CLOUD)</h2>
    <div style="margin-bottom: 20px;">
        <button id="btnNuevo">+ Nuevo Registro</button>
        <button id="btnRecargar" style="background: #3498db;">⟳ Recargar</button>
    </div>
    <div id="mensaje" class="mensaje" style="display: none;"></div>
    <div id="tabla-container"></div>

    <div id="modalForm" class="modal">
        <div class="modal-content">
            <h3 id="modalTitulo">Nuevo Registro</h3>
            <label>Descripción</label>
            <input type="text" id="descripcion" placeholder="Ej: Soldador Especializado">
            <label>Unidad</label>
            <input type="text" id="unidad" placeholder="Ej: hora, día, mes" value="hora">
            <label>Precio ($)</label>
            <input type="number" id="precio" placeholder="0">
            <label>Ubicación</label>
            <select id="ubicacion">
                <option value="taller">🔧 Taller</option>
                <option value="campo">🌾 Campo</option>
                <option value="ambos" selected>🔄 Ambos</option>
            </select>
            <div style="margin-top: 20px;">
                <button id="btnGuardar" style="background: #27ae60;">Guardar</button>
                <button id="btnCancelar" style="background: #95a5a6;">Cancelar</button>
            </div>
        </div>
    </div>

    <script>
        // IMPORTANTE: Reemplazar con tu URL real de Apps Script
        const API_URL = 'https://script.google.com/macros/s/AKfycbxtzThLpIglMqhgskt_3bYINfLLNJWNI8o6xWaL1ZiQpVkAk4trU2X8LcfXxj9pAluJug/exec';
        
        let editandoId = null;
        let contador = 1;

        function mostrarMensaje(msg, esError = false) {
            const div = document.getElementById('mensaje');
            div.textContent = msg;
            div.className = esError ? 'mensaje error' : 'mensaje exito';
            div.style.display = 'block';
            setTimeout(() => div.style.display = 'none', 3000);
        }

        async function cargarDatos() {
            try {
                const response = await fetch(`${API_URL}?accion=listar&tipo=mano_obra`);
                const result = await response.json();
                console.log('Datos recibidos:', result);
                
                if (result.success) {
                    if (result.data && result.data.length > 0) {
                        const ids = result.data.map(r => parseInt(r.id?.split('-')[1]) || 0);
                        contador = Math.max(...ids, 0) + 1;
                        renderizarTabla(result.data);
                    } else {
                        renderizarTabla([]);
                    }
                } else {
                    mostrarMensaje('Error al cargar datos: ' + (result.error || 'Desconocido'), true);
                }
            } catch(e) {
                console.error('Error:', e);
                mostrarMensaje('Error de conexión. Verifica tu internet.', true);
                document.getElementById('tabla-container').innerHTML = '<p style="color:red">❌ No se pudo conectar con el servidor</p>';
            }
        }

        function renderizarTabla(datos) {
            const container = document.getElementById('tabla-container');
            if (!datos || datos.length === 0) {
                container.innerHTML = '<p>📭 No hay registros. Haz clic en "+ Nuevo Registro" para agregar.</p>';
                return;
            }
            
            let html = `<table><thead>
                <tr>
                    <th>ID</th>
                    <th>Descripción</th>
                    <th>Unidad</th>
                    <th>Precio</th>
                    <th>Ubicación</th>
                    <th>Acciones</th>
                </tr>
            </thead><tbody>`;
            
            datos.forEach(item => {
                html += `<tr>
                    <td>${item.id || ''}</td>
                    <td>${item.descripcion || ''}</td>
                    <td>${item.unidad || ''}</td>
                    <td>$${item.precio || 0}</td>
                    <td>${item.ubicacion === 'taller' ? '🔧 Taller' : item.ubicacion === 'campo' ? '🌾 Campo' : '🔄 Ambos'}</td>
                    <td>
                        <button onclick="eliminarRegistro('${item.id}')" style="background:#e74c3c; padding:5px 10px;">🗑️ Eliminar</button>
                    </td>
                </tr>`;
            });
            html += '</tbody></table>';
            container.innerHTML = html;
        }

        async function guardarRegistro() {
            const descripcion = document.getElementById('descripcion').value.trim();
            const unidad = document.getElementById('unidad').value.trim();
            const precio = document.getElementById('precio').value;
            const ubicacion = document.getElementById('ubicacion').value;

            if (!descripcion || !unidad || !precio) {
                mostrarMensaje('❌ Complete todos los campos', true);
                return;
            }

            const nuevo = {
                id: editandoId || `MDO-${contador.toString().padStart(3, '0')}`,
                descripcion: descripcion,
                unidad: unidad,
                precio: parseFloat(precio),
                ubicacion: ubicacion
            };

            console.log('Guardando:', nuevo);

            try {
                const url = `${API_URL}?accion=guardar&tipo=mano_obra&datos=${JSON.stringify(nuevo)}`;
                const response = await fetch(url);
                const result = await response.json();
                console.log('Respuesta guardar:', result);
                
                if (result.success) {
                    mostrarMensaje('✅ Registro guardado exitosamente');
                    if (!editandoId) contador++;
                    cerrarModal();
                    await cargarDatos();
                } else {
                    mostrarMensaje('❌ Error al guardar: ' + (result.error || 'Desconocido'), true);
                }
            } catch(e) {
                console.error('Error:', e);
                mostrarMensaje('❌ Error de conexión', true);
            }
        }

        async function eliminarRegistro(id) {
            if (!confirm(`¿Eliminar el registro ${id}?`)) return;
            
            try {
                const response = await fetch(`${API_URL}?accion=eliminar&tipo=mano_obra&id=${id}`);
                const result = await response.json();
                if (result.success) {
                    mostrarMensaje('✅ Registro eliminado');
                    await cargarDatos();
                } else {
                    mostrarMensaje('❌ Error al eliminar', true);
                }
            } catch(e) {
                mostrarMensaje('❌ Error de conexión', true);
            }
        }

        function abrirModal() {
            document.getElementById('modalForm').style.display = 'block';
            editandoId = null;
            document.getElementById('descripcion').value = '';
            document.getElementById('unidad').value = 'hora';
            document.getElementById('precio').value = '';
            document.getElementById('ubicacion').value = 'ambos';
            document.getElementById('modalTitulo').textContent = '➕ Nuevo Registro';
        }

        function cerrarModal() {
            document.getElementById('modalForm').style.display = 'none';
            editandoId = null;
        }

        document.getElementById('btnNuevo').onclick = abrirModal;
        document.getElementById('btnRecargar').onclick = cargarDatos;
        document.getElementById('btnGuardar').onclick = guardarRegistro;
        document.getElementById('btnCancelar').onclick = cerrarModal;

        // Cargar datos al iniciar
        cargarDatos();
    </script>
</body>
</html>
